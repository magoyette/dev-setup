{
  "extends": "default",
  "meta": {
    "name": "opencode",
    "description": "dev-setup strict OpenCode profile"
  },
  "groups": {
    "include": [
      "opencode_linux",
      "node_runtime",
      "user_caches_linux"
    ]
  },
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "allow": [
      "$HOME/.opencode",
      "$HOME/.config/opencode",
      "$HOME/.local/share/opencode",
      "$HOME/.local/share/opentui",
      "/tmp",
      "$TMPDIR"
    ],
    "deny": [
      "$XDG_RUNTIME_DIR/herdr",
      "$XDG_RUNTIME_DIR/herdr.sock",
      "$XDG_RUNTIME_DIR/herdr/herdr.sock",
      "/tmp/herdr",
      "/tmp/herdr.sock",
      "/var/run/docker.sock",
      "$HOME/.docker"
    ]
  }
}
