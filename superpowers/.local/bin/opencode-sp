#!/usr/bin/env bash
set -euo pipefail

real_opencode="${DEV_SETUP_REAL_OPENCODE:-$HOME/.opencode/bin/opencode}"

if [[ ! -x "$real_opencode" ]]; then
  printf 'opencode-sp wrapper: real binary not found at %s\n' "$real_opencode" >&2
  exit 127
fi

export OPENCODE_ENABLE_EXA=1
export OPENCODE_CONFIG="$HOME/.config/dev-setup/opencode-superpowers.json"
exec dev-setup-ai-assistant-sandbox opencode-sp "$real_opencode" "$@"
